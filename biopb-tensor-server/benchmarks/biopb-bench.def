"""Benchmark Singularity definition file.

Based on existing Dockerfile from biopb-tensor-server.
Installs all benchmark dependencies including pytest-benchmark.
"""

Bootstrap: docker
From: python:3.12-slim

%post
    # Install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        libhdf5-dev \
        libgl1-mesa-glx \
        libglib2.0-0 \
        && rm -rf /var/lib/apt/lists/*

    # Install Python dependencies
    pip install --no-cache-dir \
        pyarrow>=14.0.0 \
        grpcio \
        zarr>=2.0.0 \
        dask[array]>=2024.0.0 \
        cachey>=0.1.0 \
        tifffile>=2021.8.30 \
        numpy<2.0 \
        h5py \
        pytest>=7.0.0 \
        pytest-benchmark>=4.0 \
        s3fs \
        fsspec \
        biopb

    # Install optional image format support
    pip install --no-cache-dir \
        aicsimageio[all]>=4.0.0 \
        ome-zarr>=0.6.1

    # Create cache directory
    mkdir -p /scratch/biopb-cache

%environment
    export S3_TEST_DATA_URL="s3://idr-public/ngff/6001240.zarr"
    export NFS_TEST_DATA_DIR="/data/microscopy"
    export PYTHONPATH="/opt/python-packages:$PYTHONPATH"

%runscript
    exec pytest benchmarks/ \
        --benchmark-only \
        --benchmark-autosave \
        --benchmark-save-data \
        --benchmark-histogram \
        -v

%labels
    Author Ji Yu
    Version 0.1.0
    Description "BioPB Tensor Server Benchmark Suite"

%help
    Benchmark suite for biopb-tensor-server.

    Usage with SLURM:
        singularity exec --bind /nfs/microscopy:/data:ro \
            --bind /scratch/$USER:/scratch \
            biopb-bench.sif \
            pytest benchmarks/ --benchmark-only

    Environment variables:
        S3_TEST_DATA_URL: Public S3 bucket for remote storage tests
        NFS_TEST_DATA_DIR: NFS mount point for local storage tests