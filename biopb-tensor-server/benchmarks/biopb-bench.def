# BioPB Tensor Server Benchmark Container
#
# Purely for running benchmarks - bootstraps from production Docker image.
# Does not start production server (that's handled by separate container).
#
# Build:
#   docker build -t jiyuuchc/biopb-tensor-server ../
#   singularity build biopb-bench.sif biopb-bench-from-docker.def
#
# Run (ephemeral test servers - cache backend configurable):
#   singularity run biopb-bench.sif                         # File cache (default)
#   singularity run --env BIOPB_CACHE_BACKEND=memory ...    # Memory cache
#   singularity run --env BIOPB_CACHE_BACKEND=file ...      # File cache
#
# Run (connect to existing production server):
#   singularity run biopb-bench.sif --bench-only
#   # Server's cache backend is already configured - BIOPB_CACHE_BACKEND has no effect
#
# Override data_sources config at runtime:
#   singularity run --bind /path/to/custom/data_sources:/app/benchmarks/data_sources biopb-bench.sif
#
# Pass pytest args:
#   singularity run biopb-bench.sif -v -k "test_name"

Bootstrap: docker
From: jiyuuchc/biopb-tensor-server:latest

%post
    # Add benchmark dependencies
    pip install --no-cache-dir \
        pytest-benchmark>=4.0 \
        pygal \
        pygaljs \
        h5py \
        s3fs \
        fsspec

    # Copy benchmarks into container (since Dockerfile doesn't include them)
    # NOTE: This requires benchmarks to exist at build time relative to SIF location
    # Alternative: bind-mount benchmarks/ at runtime with --bind
    mkdir -p /app/benchmarks
    # Benchmarks are copied via %files section below

    mkdir -p /scratch/results

%files
    # Copy benchmark suite from host at build time
    conftest.py /app/benchmarks/
    baseline_test.py /app/benchmarks/
    throughput_test.py /app/benchmarks/
    scaled_read_test.py /app/benchmarks/
    cache_perf_test.py /app/benchmarks/
    metadata_db_test.py /app/benchmarks/
    utils.py /app/benchmarks/
    __init__.py /app/benchmarks/
    data_sources /app/benchmarks/data_sources

%environment
    export S3_TEST_DATA_URL="${S3_TEST_DATA_URL:-s3://idr-public/ngff/6001240.zarr}"
    export NFS_TEST_DATA_DIR="${NFS_TEST_DATA_DIR:-/data/microscopy}"
    export NGINX_GRPC_PORT="${NGINX_GRPC_PORT:-8815}"
    export BENCH_RESULTS_DIR="${BENCH_RESULTS_DIR:-/scratch/results}"
    export BIOPB_CACHE_BACKEND="${BIOPB_CACHE_BACKEND:-file}"

%runscript
    # Usage: singularity run biopb-bench.sif [pytest_args...]
    #
    # Or set env vars:
    #   --env PYTEST_ARGS='-v -m "flight and synthetic"'
    #   --env BENCH_ONLY=1  (connect to production server)
    #
    # Cache backend (ephemeral mode): Set BIOPB_CACHE_BACKEND=memory or file
    #
    # Default: Run benchmarks with ephemeral test servers

    set -e

    RESULTS_DIR="${BENCH_RESULTS_DIR:-/scratch/results}"
    mkdir -p "$RESULTS_DIR"

    # Check mode
    if [ "${BENCH_ONLY}" = "1" ]; then
        echo "=== Running against production server ==="
        echo "Server: localhost:${NGINX_GRPC_PORT:-8815}"
        export BIOPB_BENCH_SERVER_URL="grpc://localhost:${NGINX_GRPC_PORT:-8815}"
    else
        echo "=== Running with ephemeral test servers ==="
    fi

    # Use PYTEST_ARGS env var if set, always add benchmark storage
    BENCHMARK_ARGS="--benchmark-json=$RESULTS_DIR/benchmark_results.json --benchmark-histogram=$RESULTS_DIR/benchmark_histogram"
    if [ -z "$PYTEST_ARGS" ]; then
        PYTEST_ARGS="-v --tb=short"
    fi

    echo "Pytest args: $PYTEST_ARGS"
    echo "Benchmark args: $BENCHMARK_ARGS"
    echo "Results dir: $RESULTS_DIR"
    cd /app/benchmarks
    eval pytest . $PYTEST_ARGS $BENCHMARK_ARGS -o cache_dir=$RESULTS_DIR/.pytest_cache

%labels
    Author Ji Yu
    Version 0.3.0
    Description "BioPB Tensor Server Benchmark Suite"