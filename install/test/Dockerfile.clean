# Scenario: clean Ubuntu — no uv, no Python beyond system default
# Simulates a fresh user machine with only the required tools present.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl git ca-certificates bash \
    && rm -rf /var/lib/apt/lists/*

# Seed standalone TIFFs at /root so a `BIOPB_DATA_DIR=/root bash /install.sh` run
# gives the server (install step 7) real sources to discover and pre-cache,
# mimicking a real start. (A bare fresh install instead seeds the sample bundle
# from the release and serves that.) Distinct names => each is its own dataset
# (claimed individually by aicsimageio); discovery prunes hidden dirs (~/.local,
# ~/.config), so scanning /root stays cheap. imagemagick is purged afterward.
RUN apt-get update && apt-get install -y --no-install-recommends imagemagick \
    && for n in aaa bbb ccc ddd eee; do \
         convert -size 2048x2048 xc:black +noise Gaussian \
                 -colorspace Gray -depth 16 "/root/$n.tif"; \
       done \
    && apt-get purge -y imagemagick \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

COPY ../install.sh /install.sh

CMD ["/bin/bash"]
