# Scenario: re-run / upgrade path (idempotency)
# Pre-stages uv, a biopb-tensor-server stub, and an existing config so the
# second run of install.sh can be exercised interactively.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Pre-install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Stub out biopb-tensor-server so the installer sees it as "already installed"
RUN mkdir -p /root/.local/bin \
    && printf '#!/bin/bash\necho "biopb-tensor-server 0.0.1-stub"\n' \
       > /root/.local/bin/biopb-tensor-server \
    && chmod +x /root/.local/bin/biopb-tensor-server

# Pre-create config so step 5 says "preserved"
RUN mkdir -p /root/.config/biopb && cat > /root/.config/biopb/biopb.toml << 'EOF'
[server]
host = "127.0.0.1"
port = 8815

[cache]
backend = "file"
file_max_segment_mb = 256
file_max_total_gb = 128

[[sources]]
url = "/data"
monitor = true
EOF

# Pre-create a webapp version marker so step 4 says "already up to date"
RUN mkdir -p /root/.local/share/biopb/webapp \
    && echo "v0.0.1-stub" > /root/.local/share/biopb/webapp/.version

COPY ../install.sh /install.sh

CMD ["/bin/bash"]
